readonly version="Health version: 1.13.3 - June 16, 2026"

readonly reset='\033[0m'
readonly red='\033[0;31m'
readonly green='\033[0;32m'
readonly yellow='\033[0;33m'
readonly blue='\033[0;34m'


check_df() {
    local line

    while read -r line; do
        if [[ "$line" =~ ^Filesystem ]]; then
            echo "${line}"
        elif [[ "$line" =~ 100% ]]; then
            echo "${red}${line}${reset}"
        elif [[ "$line" =~ 9[0-9]% ]]; then
            echo "${yellow}${line}${reset}"
        fi
    done < <(df -PT "$1")
}


check_mounts() {
    local line mount mount_point
    declare -a mount_errors full_inodes full_fs

    if [[ -f /etc/fstab ]] && has_cmd findmnt; then
        while read -ra line; do
            mount="${line[0]}"
            mount_point="${line[1]}"

            if [[ "${mount_point}" =~ ^/ ]] && ! findmnt "$mount" &> /dev/null; then
                mount_errors+=("${yellow}${mount} is declared in fstab but not mounted${reset}")
            fi
        done < <(awk '!/^#/' /etc/fstab)
    fi

    if timeout 2 df &> /dev/null; then
        readarray -t full_inodes < <(check_df "-hi")
        readarray -t full_fs < <(check_df "-h")
    else
        mount_errors+=("${yellow}Hung mount detected${reset}")
    fi

    if [[ -n "${mount_errors[*]}" ]]; then
        printf "%bMounts/file systems errors:%b\n" "$blue" "$reset"
        for error in "${mount_errors[@]}"; do
            printf "  %b\n" "$error"
        done
    fi

    if [[ "${#full_inodes[@]}" -gt 1 ]]; then
        printf "%bFull inodes:%b\n" "$blue" "$reset"
        for error in "${full_inodes[@]}"; do
            printf "  %b\n" "$error"
        done
    fi

    if [[ "${#full_fs[@]}" -gt 1 ]]; then
        printf "%bFull file systems:%b\n" "$blue" "$reset"
        for error in "${full_fs[@]}"; do
            printf "  %b\n" "$error"
        done
    fi
}


dmesg_parse() {
    if has_cmd dmesg && dmesg -V > /dev/null; then
        local level logs

        for level in emerg crit alert err warn; do
            readarray -t logs < <(dmesg -l "$level")

            if [[ -n "${logs[*]}" ]]; then
                if [[ "$level" =~ (emerg|crit) ]]; then
                    printf "%b%s messages%b: %d\n" "$red" "$level" "$reset" "${#logs[@]}"
                else
                    printf "%b%s messages%b: %d\n" "$yellow" "$level" "$reset" "${#logs[@]}"
                fi
            fi
        done
    fi
}


file_vulnerability() {
    local path perm

    while read -r path perm; do
        if [[ "$perm" =~ [2367]$ ]]; then
            printf "%bWorld write-able:%b %s\n" "$blue" "$reset" "$path"
        else
            printf "%bSUID/SGID:%b %s\n" "$blue" "$reset" "$path"
        fi
    done < <(find "$dir" ! -type l \( -perm -002 -o -perm -4000 -o -perm -2000 \) -printf "%p %m\n")
}


get_args() {
    local option
    declare -ag args_array

    while getopts ':defhiopr:svw:z' option; do
        case "$option" in
            d) set -x ;;
            e|f|i|o|p|s|z) args_array+=("$option") ;;
            h) usage; exit 0 ;;
            r) ssh -qt "$OPTARG" "bash -s" < "$0"; exit 0 ;;
            v) printf "%s\n" "$version"; exit 0 ;;
            w) args_array+=("$option"); declare -g user="$OPTARG" ;;
            ?)
                printf "health: invalid option -- '%s'\n" "$OPTARG" >&2
                printf "Try 'health -h' for more information.\n" >&2; exit 2
            ;;
        esac
    done

    shift "$(( OPTIND -1 ))"

    if [[ -n "${args_array[*]}" ]]; then
        if [[ -z "$1" ]]; then
            declare -g dir="$PWD"
        elif [[ -d "$1" ]]; then
            declare -g dir="$1"
        else
            printf "'%s': not a valid path.\n" "$1" >&2; exit 2
        fi
    elif [[ -z "$1" ]]; then
        health; exit 0
    else
        printf "health: invalid option -- '%s'\n" "$*" >&2
        printf "Try 'health -h' for more information.\n" >&2; exit 2
    fi
}


get_network_info() {
    local line gateway interface dns ntp nfs
    declare -a dns_servers ntp_servers
    declare -A interfaces exports

    if has_cmd ip; then
        while read -ra line; do
            if [[ "${line[0]}" == default ]]; then
                gateway="${line[2]}"
            elif [[ "${line[6]}" == link ]]; then
                interfaces["${line[2]}"]="${line[8]}"
            fi
        done < <(ip route 2> /dev/null)
    fi

    if [[ -n "${interfaces[*]}" ]]; then
        printf "%bInterface(s):%b\n" "$blue" "$reset"
        for interface in "${!interfaces[@]}"; do
            printf "  %s - %s\n" "$interface" "${interfaces[$interface]}"
        done
    fi

    if [[ -n "$gateway" ]]; then
        printf "%bDefault gateway:%b\n" "$blue" "$reset"
        if has_cmd ping; then
            if ping -W1 -c1 "$gateway" &> /dev/null; then
                printf "  %s (%breachable%b)\n" "$gateway" "$green" "$reset"
            else
                printf "  %s (%bunreachable%b)\n" "$gateway" "$yellow" "$reset"
            fi
        else
            printf "  %s\n" "$gateway"
        fi
    fi

    if has_cmd nmcli; then
        readarray -t dns_servers < \
            <(nmcli device show 2> /dev/null | awk '/DNS/ && !x[$2]++ {print $2}')

        if [[ -n "${dns_servers[*]}" ]]; then
            printf "%bDNS nameserver(s):%b\n" "$blue" "$reset"
            for dns in "${dns_servers[@]}"; do
                if timeout 1 bash -c ":> /dev/tcp/${dns}/53" &> /dev/null; then
                    printf "  %s (%breachable%b)\n" "$dns" "$green" "$reset"
                else
                    printf "  %s (%bpotential DNS error%b)\n" "$dns" "$yellow" "$reset"
                fi
            done
        fi
    fi

    if has_cmd chronyc; then
        while read -ra line; do
            case "${line[0]}" in
                ^\*) ntp_servers+=("${line[1]} (${green}current best${reset})") ;;
                ^\+) ntp_servers+=("${line[1]} (${green}combined${reset})") ;;
                ^-) ntp_servers+=("${line[1]} (${green}not combined${reset})") ;;
                ^x) ntp_servers+=("${line[1]} (${yellow}may be in error${reset})") ;;
                ^~) ntp_servers+=("${line[1]} (${red}too variable${reset})") ;;
                ^\?) ntp_servers+=("${line[1]} (${red}unusable${reset})") ;;
                *) continue ;;
            esac
        done < <(chronyc -n sources 2> /dev/null)
    fi

    if [[ -n "${ntp_servers[*]}" ]]; then
        printf "%bNTP server(s):%b\n" "$blue" "$reset"
        for ntp in "${ntp_servers[@]}"; do
            printf "  %b\n" "$ntp"
        done
    fi

    if has_cmd findmnt; then
        while read -r fstype src target; do
            exports["${fstype} - ${src}"]="$target"
        done < <(findmnt -rnt nfs,nfs4,cifs,smb3,fuse.sshfs,glusterfs,ceph,9p,lustre,fuse.davfs \
            -o FSTYPE,SOURCE,TARGET)
    fi

    if [[ -n "${exports[*]}" ]]; then
        printf "%bNetwork export(s):%b\n" "$blue" "$reset"
        for nfs in "${!exports[@]}"; do
            printf "  %s -> %s\n" "$nfs" "${exports["$nfs"]}"
        done
    fi
}


get_mem_info() {
    printf "%bMemory usage:%b\n" "$blue" "$reset"

    if [[ -f /proc/meminfo ]]; then
       local line \
        mem_total mem_available mem_percent mem_color \
        swap_total swap_free swap_percent swap_color

        while read -ra line || [[ -n "${line[*]}" ]]; do
            case "${line[0]}" in
                MemTotal:) mem_total="${line[1]}" ;;
                MemAvailable:) mem_available="${line[1]}" ;;
                SwapTotal:) swap_total="${line[1]}" ;;
                SwapFree:) swap_free="${line[1]}" ;;
                *) continue ;;
            esac
        done < /proc/meminfo

        (( mem_total > 0 )) && mem_percent=$(( ((mem_total - mem_available) * 100) / mem_total ))
        (( swap_total > 0 )) && swap_percent=$(( ((swap_total - swap_free) * 100) / swap_total ))
        (( mem_percent >= 90 )) && mem_color="$red"
        (( swap_percent >= 90 )) && swap_color="$red"

        printf "  %20s %10s %11s %11s %11s %11s %11s\n" \
            "total" "used" "free" "shared" "buff/cache" "available" "used%"

        while read -ra line; do
            case "${line[0]}" in
                Mem:)
                    printf "  %s %15s %10s %11s %11s %11s %11s %b%11s%b\n" \
                        "${line[@]}" "${mem_color:-$reset}" "${mem_percent:-0}%" "$reset"
                ;;

                Swap:)
                    printf "  %s %14s %10s %11s %b%47s%b\n" \
                       "${line[@]}" "${swap_color:-$reset}" "${swap_percent:-0}%" "$reset"
                ;;

                *) continue ;;
            esac
        done < <(free -h)
    else
        free -h
    fi
}


get_public_ip() {
    if has_cmd curl && has_cmd jq; then
        declare -a public_ip_info

        readarray -t public_ip_info < \
            <(curl --connect-timeout 5 -s ipinfo.io | jq -r '.ip, .hostname, .org' 2> /dev/null)

        [[ -n "${public_ip_info[0]}" ]] && \
            printf "%bPublic IP:%b %s\n" "$blue" "$reset" "${public_ip_info[0]}"
        [[ -n "${public_ip_info[1]}" ]] && \
            printf "%bHostname:%b %s\n" "$blue" "$reset" "${public_ip_info[1]}"
        [[ -n "${public_ip_info[2]}" ]] && \
            printf "%bISP:%b %s\n" "$blue" "$reset" "${public_ip_info[2]}"
    fi
}


has_cmd () {
    command -v "$1" &> /dev/null
}


health() {
    local product_name sys_vendor os

    product_name="/sys/devices/virtual/dmi/id/product_name"
    sys_vendor="/sys/devices/virtual/dmi/id/sys_vendor"

    printf "%bHostname:%b %s\n" "$blue" "$reset" "${HOSTNAME:-$(hostname)}"

    if [[ -f /etc/os-release ]]; then
        # shellcheck disable=1091
        os="$( (. /etc/os-release; echo "$PRETTY_NAME") )"
        [[ -n "$os" ]] && printf "%bVersion:%b %s\n" "$blue" "$reset" "$os"
    fi

    [[ -f /proc/version ]] && \
        printf "%bKernel:%b %s\n" "$blue" "$reset" "$(awk '{print $3}' /proc/version)"

    [[ -f "$product_name" && -f "$sys_vendor" ]] && \
        printf "%bHost info:%b %s, %s\n" "$blue" "$reset" "$(<"$sys_vendor")" "$(<"$product_name")"

    printf "%bUptime:%b %s\n" "$blue" "$reset" "$(uptime)"

    get_network_info
    whotf
    get_mem_info

    printf "%bTop 5 processes by memory:%b\t\t%bTop 5 processes by CPU:%b\n" \
        "$blue" "$reset" "$blue" "$reset"

    paste <(ps -eo %mem,comm,pid --sort=-%mem | head -n 6 | sed 's/^/  /') \
        <(ps -eo %cpu,comm,pid --sort=-pcpu | head -n 6 | sed 's/^/\t/')

    check_mounts
}


usage() {
    printf "Usage: health [OPTION]... [DIRECTORY]...\n"
    printf "Display general system statistics and check for common errors.\n\n"
    printf "  -d,   run in debug mode (enables 'set -x')\n"
    printf "  -e,   parse dmesg for alerts, errors, etc. (may require sudo)\n"
    printf "  -f,   report 10 largest files in specified directory tree\n"
    printf "  -h,   display this help and exit\n"
    printf "  -i,   report 10 largest directories by inode usage\n"
    printf "  -o,   show users with open files (may require sudo)\n"
    printf "  -p,   display public IP information, if available\n"
    printf "  -r,   display health on remote host\n"
    printf "  -s,   search for common file permission vulnerabilities\n"
    printf "  -v,   display version number and exit\n"
    printf "  -w,   show passwd entry for specified user\n"
    printf "  -z,   display zombie process count, if any\n\n"
    printf "Full documentation <https://github.com/zpiatt/health>\n"
}


users_with_open_files() {
    if has_cmd lsof; then
        local line
        declare -a uids

        readarray -t uids < \
            <(lsof -Fnu | awk '/^u/ { sub(/^u/, ""); if (!x[$0]++) print }' 2> /dev/null)

        printf "%-24.24s%-12.12s%-12.12s%-32.32s\n" "NAME" "UID" "GID" "FULL NAME"

        while IFS=':' read -ra line; do
            printf "%-24.24s%-12.12s%-12.12s%-32.32s\n" \
                "${line[0]}" "${line[@]:2:3}"
        done < <(getent passwd "${uids[@]}")
    fi
}


whotf() {
    declare -a users

    readarray -t users < <(who)

    if [[ -n "${users[*]}" ]]; then
        printf "%bUsers currently logged in:%b\n" "$blue" "$reset"
        printf "  %s\n" "${users[@]}"
    fi
}


main() {
    get_args "$@"

    for arg in "${args_array[@]}"; do
        case "$arg" in
            e) dmesg_parse ;;
            f) find "$dir" -xdev -type f -print0 | xargs -0 du -Sh | sort -rh | head ;;
            i) find "$dir" -xdev -printf '%h\n' | sort | uniq -c | sort -rn | head ;;
            o) users_with_open_files ;;
            p) get_public_ip ;;
            s) file_vulnerability ;;
            w) getent passwd "$user" ;;
            z) ps axo stat | awk 'BEGIN{i=0}/Z/{i++;}END{print i}' ;;
        esac
    done

    return 0
}

main "$@"
